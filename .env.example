# ── Backend (required) ─────────────────────────
MONGO_URI=mongodb://USER:PASS@HOST:27017/
MONGO_DB=ev_monitor
MQTT_URL=mqtt://MQTT_HOST:1883
WS_PORT=4100
HEARTBEAT_TIMEOUT_MS=300000

# ── Config page protection ─────────────────────
# PIN required to access /config and POST /api/stations/save
CONFIG_PIN=1234

# ── Frontend (optional overrides) ──────────────
# Leave UNSET in production — frontend auto-detects hostname from window.location
# Only set these when serving WS/API on a different domain (e.g. behind nginx).
#
# NEXT_PUBLIC_WS_URL=wss://dashboard.example.com/ws
# NEXT_PUBLIC_API_URL=https://dashboard.example.com/api
